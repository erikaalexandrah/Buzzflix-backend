PORT=3000
TMDB_API_KEY=replace-with-your-tmdb-api-key
TMDB_BASE_URL=https://api.themoviedb.org/3

# Neo4j local (Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=buzzflix-local-password

JWT_SECRET=replace-with-a-long-random-secret

# Cuenta admin que se garantiza al arrancar el servidor.
# Si ambas variables están definidas, el usuario se crea (o se actualiza a admin)
# en el arranque. El registro público nunca crea admins.
ADMIN_EMAIL=erika.zurilla@gmail.com
ADMIN_PASSWORD=erikazurilla116

# Incremental TMDB import
RECENT_MOVIES_REFRESH_PAGES=2
RECENT_MOVIES_BACKFILL_PAGES_PER_RUN=5

# Si la BD arranca vacía, sembrarla automáticamente desde TMDB al iniciar.
# Ponlo en "false" para desactivar la siembra automática.
SEED_ON_EMPTY=true
